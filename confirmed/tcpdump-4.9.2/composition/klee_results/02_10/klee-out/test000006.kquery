array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 122641721589760 (ZExt w64 N0))
                  122641721589762))
         (Eq false
             (Sle (ZExt w32 (Read w8 1 buf))
                  3))
         (Eq false (Ult N1 122641721589765))]
        false)
