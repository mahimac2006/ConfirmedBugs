array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 131963392360448 (ZExt w64 N0))
                  131963392360450))
         (Eq false
             (Eq 6 (Read w8 0 buf)))
         (Eq false (Ult N0 4))
         (Ult 131963392360452 N1)
         (Eq false (Ult N1 131963392360456))]
        false)
