                           N12:(SExt w64 (Add w32 6 N13:(Add w32 N9 N10))))))
         (Eq 5
             (Read w8 (Extract w32 0 N12)
                      buf))
         (Eq false
             (Ult N2 (Add w64 130196145438722 N12)))
         (Sle N14:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 7 N13)))
                                     buf))
              3)
         (Ult 0
              (Add w32 4294967288 N15:(Sub w32 N11 N14)))
         (Eq false
             (Ult N2
                  (Add w64 130196145438721
                           N16:(SExt w64 (Add w32 8 N17:(Add w32 N13 N14))))))
         (Eq false
