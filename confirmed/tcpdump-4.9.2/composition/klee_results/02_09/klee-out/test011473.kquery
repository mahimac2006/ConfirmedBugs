         (Ult 0
              (Add w32 4294967284
                       (Sub w32 N18
                                N22:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 11 N21)))
                                                       buf)))))
         (Ult N2
              (Add w64 130196145438721
                       (SExt w64 (Add w32 12 (Add w32 N21 N22)))))
         (Eq false (Eq 255 N1))
