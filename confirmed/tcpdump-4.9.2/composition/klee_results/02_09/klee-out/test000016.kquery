array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 130196145438720 (ZExt w64 N0))
                  130196145438722))
         (Eq false (Ult N1 130196145438725))
         (Eq 255 (Read w8 1 buf))
         (Eq false (Ult N1 130196145438737))]
        false)
