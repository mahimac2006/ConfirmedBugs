array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 130196145438720 (ZExt w64 N0))
                  130196145438722))
         (Ult 0
              (Add w32 4294967294
                       N3:(Sub w32 N0
