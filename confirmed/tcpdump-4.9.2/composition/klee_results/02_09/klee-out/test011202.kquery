                       N6:(Sub w32 N3
                                   N7:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N4)))
                                                         buf)))))
         (Eq false
             (Ult N2
                  (Add w64 130196145438721
                           N8:(SExt w64 (Add w32 4 N9:(Add w32 N4 N7))))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N8)
                          buf)))
         (Eq false
             (Ult N2 (Add w64 130196145438722 N8)))
         (Ult 0
              (Add w32 4294967290
                       (Sub w32 N6
                                N10:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N9)))
                                                       buf)))))
         (Eq false
             (Ult N2
                  (Add w64 130196145438721
                           N11:(SExt w64 (Add w32 6 N12:(Add w32 N9 N10))))))
         (Eq 5
             (Read w8 (Extract w32 0 N11)
                      buf))
         (Eq false
             (Ult N2 (Add w64 130196145438722 N11)))
         (Eq false
             (Sle (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 7 N12)))
                                     buf))
                  3))
         (Ult N2
              (Add w64 130196145438723
                       (SExt w64 (Add w32 8 N12))))
         (Eq false (Eq 255 N1))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Eq false
