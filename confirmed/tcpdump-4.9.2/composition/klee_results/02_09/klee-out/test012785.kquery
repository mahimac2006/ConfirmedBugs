         (Ult 130196145438733 N2)
         (Eq false
             (Eq 255 (Read w8 13 buf)))
         (Ult 130196145438734 N2)
         (Eq 255 (Read w8 14 buf))
         (Ult N2 130196145438750)]
        false)
