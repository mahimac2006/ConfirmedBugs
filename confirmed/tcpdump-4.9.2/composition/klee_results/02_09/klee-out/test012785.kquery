         (Ult 0
              (Add w32 4294967292 N7:(Sub w32 N3 N6)))
         (Eq false
             (Ult N2
                  (Add w64 130196145438721
                           N8:(SExt w64 (Add w32 4 N9:(Add w32 N4 N6))))))
         (Eq 5
             (Read w8 (Extract w32 0 N8)
                      buf))
         (Eq false
             (Ult N2 (Add w64 130196145438722 N8)))
         (Sle N10:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N9)))
                                     buf))
              3)
         (Ult 0
              (Add w32 4294967290 (Sub w32 N7 N10)))
         (Eq false
             (Ult N2
                  (Add w64 130196145438721
                           N11:(SExt w64 (Add w32 6 (Add w32 N9 N10))))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N11)
                          buf)))
         (Ult N2 (Add w64 130196145438722 N11))
         (Eq false (Eq 255 N1))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Eq false
