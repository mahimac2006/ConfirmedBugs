array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Sle N2:(ZExt w32 (Read w8 1 buf))
              3)
         (Ult 0
              (Add w32 4294967294 N3:(Sub w32 N0 N2)))
         (Eq false
             (Ult N1
                  (Add w64 127512497618945
                           N4:(SExt w64 (Add w32 2 N2)))))
         (Eq 5
             (Read w8 (Extract w32 0 N4)
                      buf))
         (Eq false
             (Ult N1 (Add w64 127512497618946 N4)))
         (Sle N5:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N2)))
                                    buf))
              3)
         (Ult 0
              (Add w32 4294967292 N6:(Sub w32 N3 N5)))
         (Eq false
             (Ult N1
                  (Add w64 127512497618945
                           N7:(SExt w64 (Add w32 4 N8:(Add w32 N2 N5))))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N7)
                          buf)))
         (Eq false
             (Ult N1 (Add w64 127512497618946 N7)))
         (Eq false
             (Ult 0
                  (Add w32 4294967290
                           (Sub w32 N6
                                    (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N8)))
                                                       buf))))))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq 255 (Read w8 3 buf))
         (Eq false (Ult N1 127512497618963))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq false
             (Eq 255 (Read w8 6 buf)))
         (Eq false
             (Eq 255 (Read w8 7 buf)))
         (Eq false
             (Eq 255 (Read w8 8 buf)))
         (Eq false
             (Eq 255 (Read w8 9 buf)))
         (Eq false
             (Eq 255 (Read w8 10 buf)))
         (Eq 255 (Read w8 11 buf))
         (Eq false (Ult N1 127512497618971))]
        false)
