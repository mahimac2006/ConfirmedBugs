array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Ult 0
              (Add w32 4294967294
                       N3:(Sub w32 N0
                                   N4:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N2
                  (Add w64 127512497618945
                           N5:(SExt w64 (Add w32 2 N4)))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N5)
                          buf)))
         (Eq false
             (Ult N2 (Add w64 127512497618946 N5)))
         (Ult 0
              (Add w32 4294967292
                       N6:(Sub w32 N3
                                   N7:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N4)))
                                                         buf)))))
         (Eq false
             (Ult N2
                  (Add w64 127512497618945
                           N8:(SExt w64 (Add w32 4 N9:(Add w32 N4 N7))))))
         (Eq 5
             (Read w8 (Extract w32 0 N8)
                      buf))
         (Eq false
             (Ult N2 (Add w64 127512497618946 N8)))
         (Sle N10:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N9)))
                                     buf))
              3)
         (Eq false
             (Ult 0
                  (Add w32 4294967290 (Sub w32 N6 N10))))
         (Eq false (Eq 255 N1))
         (Eq 255 (Read w8 2 buf))
         (Eq false (Ult N2 127512497618962))
         (Eq false
             (Eq 255 (Read w8 3 buf)))]
        false)
