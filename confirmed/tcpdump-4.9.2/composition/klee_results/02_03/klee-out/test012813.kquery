array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Eq false
             (Ult 0
                  (Add w32 4294967294
                           (Sub w32 N0
                                    (ZExt w32 (Read w8 1 buf))))))
         (Eq false (Eq 255 N1))
         (Ult 127512497618946 N2)
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Ult 127512497618947 N2)
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Ult 127512497618948 N2)
         (Eq 255 (Read w8 4 buf))
         (Eq false (Ult N2 127512497618964))
         (Eq 255 (Read w8 5 buf))
         (Eq false
             (Eq 255 (Read w8 6 buf)))
         (Eq false (Ult N2 127512497618965))
         (Eq false
             (Eq 255 (Read w8 7 buf)))
         (Eq 255 (Read w8 8 buf))
         (Eq false (Ult N2 127512497618968))
         (Eq false
             (Eq 255 (Read w8 9 buf)))
         (Eq 255 (Read w8 10 buf))
         (Eq false (Ult N2 127512497618970))
         (Eq false
             (Eq 255 (Read w8 11 buf)))
         (Eq false
             (Eq 255 (Read w8 12 buf)))
         (Eq false
             (Eq 255 (Read w8 13 buf)))]
        false)
