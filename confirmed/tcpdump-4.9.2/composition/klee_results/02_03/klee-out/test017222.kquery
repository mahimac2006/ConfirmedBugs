array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Ult 0
              (Add w32 4294967294
                       (Sub w32 N0
                                N2:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N1
                  (Add w64 127512497618945
                           N3:(SExt w64 (Add w32 2 N2)))))
         (Eq 5
             (Read w8 (Extract w32 0 N3)
                      buf))
         (Ult N1 (Add w64 127512497618946 N3))
         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 127512497618960))
         (Eq 255 (Read w8 2 buf))
         (Eq false (Ult N1 127512497618962))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Eq 255 (Read w8 6 buf))
         (Eq false (Ult N1 127512497618966))
         (Eq 255 (Read w8 7 buf))
         (Eq false
             (Eq 255 (Read w8 8 buf)))
         (Eq false (Ult N1 127512497618967))]
        false)
