array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Ult 0
              (Add w32 4294967294
                       N3:(Sub w32 N0
                                   N4:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N2
                  (Add w64 127512497618945
                           N5:(SExt w64 (Add w32 2 N4)))))
         (Eq 5
             (Read w8 (Extract w32 0 N5)
                      buf))
         (Eq false
             (Ult N2 (Add w64 127512497618946 N5)))
         (Sle N6:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N4)))
                                    buf))
              3)
         (Ult 0
              (Add w32 4294967292 (Sub w32 N3 N6)))
         (Ult N2
              (Add w64 127512497618945
                       (SExt w64 (Add w32 4 (Add w32 N4 N6)))))
         (Eq false (Eq 255 N1))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Ult 127512497618948 N2)
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Ult 127512497618949 N2)
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Ult 127512497618950 N2)
         (Eq false
             (Eq 255 (Read w8 6 buf)))
         (Ult 127512497618951 N2)
         (Eq false
             (Eq 255 (Read w8 7 buf)))
         (Ult 127512497618952 N2)
         (Eq 255 (Read w8 8 buf))
         (Eq false (Ult N2 127512497618968))]
        false)
