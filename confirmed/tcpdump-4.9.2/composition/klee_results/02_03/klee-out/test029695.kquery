array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 127512497618944 (ZExt w64 N0))
                  127512497618946))
         (Ult 0
              (Add w32 4294967294
                       N2:(Sub w32 N0
                                   N3:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N1
                  (Add w64 127512497618945
                           N4:(SExt w64 (Add w32 2 N3)))))
         (Eq 5
             (Read w8 (Extract w32 0 N4)
                      buf))
         (Eq false
             (Ult N1 (Add w64 127512497618946 N4)))
         (Sle N5:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N3)))
                                    buf))
              3)
         (Ult 0
              (Add w32 4294967292 N6:(Sub w32 N2 N5)))
         (Eq false
             (Ult N1
                  (Add w64 127512497618945
                           N7:(SExt w64 (Add w32 4 N8:(Add w32 N3 N5))))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N7)
                          buf)))
         (Eq false
             (Ult N1 (Add w64 127512497618946 N7)))
         (Eq false
             (Ult 0
                  (Add w32 4294967290
                           (Sub w32 N6
                                    (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N8)))
                                                       buf))))))
         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 127512497618960))
         (Eq 255 (Read w8 2 buf))
         (Eq false (Ult N1 127512497618962))
         (Eq 255 (Read w8 3 buf))
         (Eq 255 (Read w8 4 buf))]
        false)
