array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 132355037593600 (ZExt w64 N0))
                  132355037593602))
         (Ult 0
              (Add w32 4294967294
                       N3:(Sub w32 N0
                                   N4:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N2
                  (Add w64 132355037593601
                           N5:(SExt w64 (Add w32 2 N4)))))
         (Eq 5
             (Read w8 (Extract w32 0 N5)
                      buf))
         (Eq false
             (Ult N2 (Add w64 132355037593602 N5)))
         (Sle N6:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N4)))
                                    buf))
              3)
         (Ult 0
              (Add w32 4294967292 (Sub w32 N3 N6)))
         (Eq false
             (Ult N2
                  (Add w64 132355037593601
                           N7:(SExt w64 (Add w32 4 N8:(Add w32 N4 N6))))))
         (Eq 5
             (Read w8 (Extract w32 0 N7)
                      buf))
         (Eq false
             (Ult N2 (Add w64 132355037593602 N7)))
         (Eq false
             (Sle (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N8)))
                                     buf))
                  3))
         (Eq false
             (Ult N2
                  (Add w64 132355037593603
                           (SExt w64 (Add w32 6 N8)))))
         (Eq false (Eq 255 N1))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq 255 (Read w8 4 buf))
         (Ult N2 132355037593620)]
        false)
