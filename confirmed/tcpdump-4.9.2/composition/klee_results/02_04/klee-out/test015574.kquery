         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 132355037593616))
         (Eq false (Eq 255 N3))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Eq false
