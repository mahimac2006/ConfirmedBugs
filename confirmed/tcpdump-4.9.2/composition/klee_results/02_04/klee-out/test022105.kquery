array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 132355037593600 (ZExt w64 N0))
                  132355037593602))
         (Sle N2:(ZExt w32 (Read w8 1 buf))
              3)
         (Ult 0
              (Add w32 4294967294 N3:(Sub w32 N0 N2)))
         (Eq false
             (Ult N1
                  (Add w64 132355037593601
                           N4:(SExt w64 (Add w32 2 N2)))))
         (Eq false
             (Eq 5
                 (Read w8 (Extract w32 0 N4)
                          buf)))
         (Eq false
             (Ult N1 (Add w64 132355037593602 N4)))
         (Ult 0
              (Add w32 4294967292
                       N5:(Sub w32 N3
                                   N6:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N2)))
                                                         buf)))))
         (Eq false
             (Ult N1
                  (Add w64 132355037593601
                           N7:(SExt w64 (Add w32 4 N8:(Add w32 N2 N6))))))
         (Eq 5
             (Read w8 (Extract w32 0 N7)
                      buf))
         (Eq false
             (Ult N1 (Add w64 132355037593602 N7)))
         (Sle N9:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 5 N8)))
                                    buf))
              3)
         (Ult 0
              (Add w32 4294967290 N10:(Sub w32 N5 N9)))
         (Eq false
             (Ult N1
                  (Add w64 132355037593601
                           N11:(SExt w64 (Add w32 6 N12:(Add w32 N8 N9))))))
         (Eq 5
             (Read w8 (Extract w32 0 N11)
                      buf))
         (Eq false
             (Ult N1 (Add w64 132355037593602 N11)))
         (Sle N13:(ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 7 N12)))
                                     buf))
              3)
         (Ult 0
              (Add w32 4294967288 (Sub w32 N10 N13)))
         (Eq false
             (Ult N1
                  (Add w64 132355037593601
                           N14:(SExt w64 (Add w32 8 N15:(Add w32 N12 N13))))))
         (Eq 5
             (Read w8 (Extract w32 0 N14)
                      buf))
         (Eq false
             (Ult N1 (Add w64 132355037593602 N14)))
         (Eq false
             (Sle (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 9 N15)))
                                     buf))
                  3))]
        false)
