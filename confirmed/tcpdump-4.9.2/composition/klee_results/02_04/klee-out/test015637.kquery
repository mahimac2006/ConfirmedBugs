array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 132355037593600 (ZExt w64 N0))
                  132355037593602))
         (Ult 0
              (Add w32 4294967294
                       (Sub w32 N0
                                N2:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N1
                  (Add w64 132355037593601
                           N3:(SExt w64 (Add w32 2 N2)))))
         (Eq 5
             (Read w8 (Extract w32 0 N3)
                      buf))
         (Eq false
             (Ult N1 (Add w64 132355037593602 N3)))
         (Eq false
             (Sle (ZExt w32 (Read w8 (Extract w32 0 (SExt w64 (Add w32 3 N2)))
                                     buf))
                  3))
         (Ult N1
              (Add w64 132355037593603
                       (SExt w64 (Add w32 4 N2))))
         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 132355037593616))
         (Eq 255 (Read w8 2 buf))
         (Eq false (Ult N1 132355037593618))
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Eq 255 (Read w8 4 buf))
         (Eq false (Ult N1 132355037593620))
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Eq 255 (Read w8 6 buf))
         (Eq false (Ult N1 132355037593622))
         (Eq false
             (Eq 255 (Read w8 7 buf)))]
        false)
