array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Eq 5 N1:(Read w8 0 buf)))
         (Eq false
             (Ult N2:(Add w64 132355037593600 (ZExt w64 N0))
                  132355037593602))
         (Ult 0
              (Add w32 4294967294
                       (Sub w32 N0
                                N3:(ZExt w32 (Read w8 1 buf)))))
         (Eq false
             (Ult N2
                  (Add w64 132355037593601
                           N4:(SExt w64 (Add w32 2 N3)))))
         (Eq 5
             (Read w8 (Extract w32 0 N4)
                      buf))
         (Ult N2 (Add w64 132355037593602 N4))
         (Eq false (Eq 255 N1))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Ult 132355037593603 N2)
         (Eq false
             (Eq 255 (Read w8 3 buf)))
         (Ult 132355037593604 N2)
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Ult 132355037593605 N2)
         (Eq false
             (Eq 255 (Read w8 5 buf)))
         (Ult 132355037593606 N2)
         (Eq false
             (Eq 255 (Read w8 6 buf)))
         (Ult 132355037593607 N2)
         (Eq 255 (Read w8 7 buf))
         (Eq false (Ult N2 132355037593623))
         (Eq false
             (Eq 255 (Read w8 8 buf)))
         (Eq 255 (Read w8 9 buf))
         (Eq false (Ult N2 132355037593625))]
        false)
