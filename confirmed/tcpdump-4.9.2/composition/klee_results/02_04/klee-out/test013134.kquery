array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 132355037593600 (ZExt w64 N0))
                  132355037593602))
         (Eq false
             (Sle (ZExt w32 N2:(Read w8 1 buf))
                  3))
         (Eq false (Ult N1 132355037593605))
         (Eq false (Eq 255 N2))
         (Eq false
             (Eq 255 (Read w8 2 buf)))
         (Eq 255 (Read w8 3 buf))
         (Eq false (Ult N1 132355037593619))
         (Eq false
             (Eq 255 (Read w8 4 buf)))
         (Eq 255 (Read w8 5 buf))
         (Eq false (Ult N1 132355037593621))
         (Eq 255 (Read w8 6 buf))
         (Eq false
             (Eq 255 (Read w8 7 buf)))
         (Eq false (Ult N1 132355037593622))
         (Eq 255 (Read w8 8 buf))
         (Eq false (Ult N1 132355037593624))
         (Eq false
             (Eq 255 (Read w8 9 buf)))
         (Eq 255 (Read w8 10 buf))
         (Eq false (Ult N1 132355037593626))
         (Eq false
             (Eq 255 (Read w8 11 buf)))
         (Eq false
             (Eq 255 (Read w8 12 buf)))]
        false)
