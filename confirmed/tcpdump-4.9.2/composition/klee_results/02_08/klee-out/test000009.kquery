array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq 5 (Read w8 0 buf))
         (Eq false
             (Ult N1:(Add w64 139499570987008 (ZExt w64 N0))
                  139499570987010))
         (Eq false
             (Sle (ZExt w32 (Read w8 1 buf))
                  3))
         (Eq false (Ult N1 139499570987013))
         (Eq false (Ult N1 139499570987024))]
        false)
