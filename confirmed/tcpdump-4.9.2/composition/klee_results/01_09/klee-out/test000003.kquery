array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 136881123622912 (ZExt w64 N0))
                  136881123622914))
         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 136881123622928))]
        false)
