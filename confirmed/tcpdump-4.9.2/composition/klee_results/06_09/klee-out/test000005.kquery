array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false (Ult N0 4))
         (Ult 139127894835204
              N1:(Add w64 139127894835200 (ZExt w64 N0)))
         (Eq false (Ult N1 139127894835208))
         (Eq 255 (Read w8 0 buf))
         (Eq false (Ult N1 139127894835216))]
        false)
