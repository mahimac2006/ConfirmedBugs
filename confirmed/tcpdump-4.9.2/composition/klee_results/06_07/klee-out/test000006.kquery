array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false (Ult N0 4))
         (Ult 125690760396804
              N1:(Add w64 125690760396800 (ZExt w64 N0)))
         (Eq false (Ult N1 125690760396808))
         (Eq false
             (Eq 170 (Read w8 0 buf)))]
        false)
