array buf[64] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 64)
         (Eq false
             (Ult N1:(Add w64 126736341663744 (ZExt w64 N0))
                  126736341663746))
         (Eq false
             (Eq 6 N2:(Read w8 0 buf)))
         (Eq false (Ult N1 126736341663750))
         (Eq false (Eq 170 N2))]
        false)
