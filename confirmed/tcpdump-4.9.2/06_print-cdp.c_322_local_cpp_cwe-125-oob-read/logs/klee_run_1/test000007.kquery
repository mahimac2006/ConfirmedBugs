array buf[64] : w32 -> w8 = symbolic
(query [(Eq false
             (Slt N0:(Or w32 (Shl w32 (ZExt w32 (Read w8 6 buf))
                                      8)
                             (ZExt w32 (Read w8 7 buf)))
                  4))
         (Eq 1
             (Or w32 (Shl w32 (ZExt w32 (Read w8 4 buf))
                              8)
                     (ZExt w32 (Read w8 5 buf))))
         (Ult (Add w64 123217723494408
                       N1:(SExt w64 (Add w32 4294967292 N0)))
              123217723494464)
         (Ult (Add w64 9 N1) 64)
         (Ult N2:(Add w64 10 N1) 64)
         (Ult N3:(Add w64 11 N1) 64)
         (Slt (Or w32 (Shl w32 (ZExt w32 (Read w8 (Extract w32 0 N2)
                                                  U0:[3=16, 2=0, 1=0, 0=0] @ buf))
                               8)
                      (ZExt w32 (Read w8 (Extract w32 0 N3)
                                         U0)))
              4)]
        false)
