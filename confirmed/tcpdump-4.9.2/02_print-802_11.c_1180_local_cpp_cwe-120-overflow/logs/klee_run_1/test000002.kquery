array buf[512] : w32 -> w8 = symbolic
(query [(Eq 5 (Read w8 0 buf))
         (Sle N0:(ZExt w32 (Read w8 1 buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N1:(SExt w64 (Add w32 2 N0)))
                      buf))
         (Sle N2:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N1))
                                    buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N3:(SExt w64 (Add w32 4 N4:(Add w32 N0 N2))))
                      buf))
         (Sle N5:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N3))
                                    buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N6:(SExt w64 (Add w32 6 N7:(Add w32 N4 N5))))
                      buf))
         (Sle N8:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N6))
                                    buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N9:(SExt w64 (Add w32 8 N10:(Add w32 N7 N8))))
                      buf))
         (Sle N11:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N9))
                                     buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N12:(SExt w64 (Add w32 10 N13:(Add w32 N10 N11))))
                      buf))
         (Sle N14:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N12))
                                     buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N15:(SExt w64 (Add w32 12 N16:(Add w32 N13 N14))))
                      buf))
         (Sle N17:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N15))
                                     buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N18:(SExt w64 (Add w32 14 N19:(Add w32 N16 N17))))
                      buf))
         (Sle N20:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N18))
                                     buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 (SExt w64 (Add w32 16 (Add w32 N19 N20))))
                      buf))]
        false)
