array buf[512] : w32 -> w8 = symbolic
(query [(Eq 5 (Read w8 0 buf))
         (Eq 4 (Read w8 1 buf))
         (Eq 5 (Read w8 6 buf))
         (Eq 4 (Read w8 7 buf))
         (Eq 5 (Read w8 12 buf))
         (Sle N0:(ZExt w32 (Read w8 13 buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N1:(SExt w64 (Add w32 14 N0)))
                      buf))
         (Sle N2:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N1))
                                    buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N3:(SExt w64 (Add w32 16 N4:(Add w32 N0 N2))))
                      buf))
         (Sle N5:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N3))
                                    buf))
              3)
         (Eq 5
             (Read w8 (Extract w32 0 N6:(SExt w64 (Add w32 18 (Add w32 N4 N5))))
                      buf))
         (Sle (ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N6))
                                 buf))
              3)]
        false)
