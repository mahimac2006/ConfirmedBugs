array buf[256] : w32 -> w8 = symbolic
array size_used[4] : w32 -> w8 = symbolic
array value[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Eq 0
                 N0:(ReadLSB w32 0 size_used)))
         (Ult (Add w32 11 N0) 257)
         (Ult 999999999
              (ReadLSB w32 0 value))
         (Eq 49 (Read w8 0 buf))
         (Eq 32 (Read w8 1 buf))
         (Eq false
             (Eq 32 (Read w8 2 buf)))
         (Ult (Add w8 208 (Read w8 3 buf))
              10)
         (Ult (Add w8 208 (Read w8 4 buf))
              10)
         (Ult (Add w8 208 (Read w8 5 buf))
              10)
         (Ult (Add w8 208 (Read w8 6 buf))
              10)
         (Ult (Add w8 208 (Read w8 7 buf))
              10)
         (Eq 32 (Read w8 8 buf))
         (Ult (Add w8 208 (Read w8 9 buf))
              10)
         (Eq 32 (Read w8 10 buf))
         (Eq 32 (Read w8 11 buf))
         (Ult (Add w8 208 (Read w8 12 buf))
              10)
         (Ult (Add w8 208 (Read w8 13 buf))
              10)
         (Ult (Add w8 208 (Read w8 14 buf))
              10)
         (Eq 32 (Read w8 15 buf))
         (Or (Ult (Add w8 208 N1:(Read w8 16 buf))
                  10)
             (Ult (Add w8 191 N1) 26))
         (Or (Ult (Add w8 208 N2:(Read w8 17 buf))
                  10)
             (Ult (Add w8 191 N2) 26))
         (Or (Ult (Add w8 208 N3:(Read w8 18 buf))
                  10)
             (Ult (Add w8 191 N3) 26))
         (Or (Ult (Add w8 208 N4:(Read w8 19 buf))
                  10)
             (Ult (Add w8 191 N4) 26))
         (Eq false
             (Ult (Add w8 208 N5:(Read w8 20 buf))
                  10))
         (Eq false
             (Ult (Add w8 191 N5) 26))
         (Or (Ult 256 N0)
             (Ult (Sub w32 256 N0) 11))]
        false)
