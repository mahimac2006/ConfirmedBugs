array buf[256] : w32 -> w8 = symbolic
array size_used[4] : w32 -> w8 = symbolic
array value[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Eq 0
                 N0:(ReadLSB w32 0 size_used)))
         (Ult (Add w32 11 N0) 257)
         (Ult 999999999
              (ReadLSB w32 0 value))
         (Eq false
             (Eq 49 (Read w8 0 buf)))
         (Or (Ult 256 N0)
             (Ult (Sub w32 256 N0) 11))]
        false)
