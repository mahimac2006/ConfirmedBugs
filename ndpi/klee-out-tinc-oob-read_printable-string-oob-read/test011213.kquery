array buf[256] : w32 -> w8 = symbolic
array ps_len[8] : w32 -> w8 = symbolic
(query [(Ult 256
              N0:(ReadLSB w64 0 ps_len))
         (Ult N0 513)
         (Eq 49 (Read w8 0 buf))
         (Eq 32 (Read w8 1 buf))
         (Eq false
             (Eq 32 (Read w8 2 buf)))
         (Ult (Add w8 208 (Read w8 3 buf))
              10)
         (Ult (Add w8 208 (Read w8 4 buf))
              10)
         (Ult (Add w8 208 (Read w8 5 buf))
              10)
         (Ult (Add w8 208 (Read w8 6 buf))
              10)
         (Ult (Add w8 208 (Read w8 7 buf))
              10)
         (Ult (Add w8 208 (Read w8 8 buf))
              10)
         (Ult (Add w8 208 (Read w8 9 buf))
              10)
         (Ult (Add w8 208 (Read w8 10 buf))
              10)
         (Ult (Add w8 208 (Read w8 11 buf))
              10)
         (Eq 32 (Read w8 12 buf))
         (Eq 32 (Read w8 13 buf))
         (Ult (Add w8 208 (Read w8 14 buf))
              10)
         (Ult (Add w8 208 (Read w8 15 buf))
              10)
         (Eq 32 (Read w8 16 buf))
         (Ult (Add w8 208 (Read w8 17 buf))
              10)
         (Ult (Add w8 208 (Read w8 18 buf))
              10)
         (Ult (Add w8 208 (Read w8 19 buf))
              10)
         (Eq 32 (Read w8 20 buf))
         (Or (Ult (Add w8 208 N1:(Read w8 21 buf))
                  10)
             (Ult (Add w8 191 N1) 26))
         (Eq false
             (Ult (Add w8 208 N2:(Read w8 22 buf))
                  10))
         (Eq false
             (Ult (Add w8 191 N2) 26))]
        false)
