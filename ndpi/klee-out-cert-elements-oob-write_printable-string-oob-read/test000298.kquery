              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N16))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N17:(Add w16 8 N11)))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N18:(ZExt w64 N17))
                      buf))
         (Eq 29
             (Read w8 (Extract w32 0 (Add w64 1 N18))
                      buf))
         (Eq 17
             (Read w8 (Extract w32 0 (Add w64 2 N18))
                      buf))
         (Ult N19:(Add w16 11 N11) 256)
         (Ult (Add w16 8
