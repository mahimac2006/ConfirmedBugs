                                                                         buf)
                                                             0)
                                                        (And w8 N8 127)
                                                        0))))
              256)
         (Ult N9:(Add w16 3 N7) 256)
         (Ult N10:(Add w16 4
                           N11:(Add w16 N7
                                        (ZExt w16 (Select w8 (Slt N12:(Read w8 (Extract w32 0 (ZExt w64 N9))
                                                                               buf)
                                                                  0)
                                                             (And w8 N12 127)
                                                             0))))
              256)
         (Eq false
             (Eq 129
                 N13:(Read w8 (Extract w32 0 (ZExt w64 N10))
                              buf)))
         (Eq false (Eq 130 N13))
         (Eq false (Eq 135 N13))
         (Ult N14:(Add w16 5 N11) 256)
         (Ult (Add w32 2 (ZExt w32 N14))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N14))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N15:(Add w16 6 N11)))
              256)
         (Eq false
