                                                               buf))
                                                  4
                                                  7)
                                      N0))
              256)
         (Ult (Add w16 1
                       N7:(Add w16 N6
                                   (ZExt w16 (Select w8 (Slt N8:(Read w8 (Extract w32 0 (ZExt w64 N5))
                                                                         buf)
                                                             0)
                                                        (And w8 N8 127)
                                                        0))))
              256)
         (Ult N9:(Add w16 3 N7) 256)
         (Ult N10:(Add w16 4
                           N11:(Add w16 N7
                                        (ZExt w16 (Select w8 (Slt N12:(Read w8 (Extract w32 0 (ZExt w64 N9))
                                                                               buf)
                                                                  0)
                                                             (And w8 N12 127)
                                                             0))))
              256)
         (Eq false
             (Eq 129
                 N13:(Read w8 (Extract w32 0 (ZExt w64 N10))
                              buf)))
         (Eq false (Eq 130 N13))
         (Eq false (Eq 135 N13))
         (Ult N14:(Add w16 5 N11) 256)
         (Ult (Add w32 2 (ZExt w32 N14))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N15:(ZExt w64 N14))
                      buf))
         (Eq 29
             (Read w8 (Extract w32 0 (Add w64 1 N15))
                      buf))
         (Eq 17
             (Read w8 (Extract w32 0 (Add w64 2 N15))
                      buf))
         (Ult N16:(Add w16 8 N11) 256)
         (Ult N17:(Add w16 5
                           N18:(Add w16 (Select w16 (Eq 4
                                                        (Read w8 (Extract w32 0 (ZExt w64 N16))
                                                                 buf))
                                                    4
                                                    7)
                                        N11))
              256)
         (Ult (Add w16 5
                       N19:(Add w16 N18
                                    (ZExt w16 (Select w8 (Slt N20:(Read w8 (Extract w32 0 (ZExt w64 N17))
                                                                           buf)
                                                              0)
                                                         (And w8 N20 127)
                                                         0))))
              256)
         (Ult N21:(Add w16 7 N19) 256)
         (Ult N22:(Add w16 8
                           (Add w16 N19
                                    (ZExt w16 (Select w8 (Slt N23:(Read w8 (Extract w32 0 (ZExt w64 N21))
                                                                           buf)
                                                              0)
                                                         (And w8 N23 127)
                                                         0))))
              256)
         (Or (Eq 135
                 N24:(Read w8 (Extract w32 0 N25:(ZExt w64 N22))
                              buf))
             (Or (Eq 130 N24) (Eq 129 N24)))
         (Ult (Add w32 1 N26:(ZExt w32 N22))
              256)
         (Eq false
             (Ult (Add w32 2
                           (Add w32 N26
                                    (ZExt w32 (Read w8 (Extract w32 0 (Add w64 1 N25))
                                                       buf))))
                  256))]
        false)
