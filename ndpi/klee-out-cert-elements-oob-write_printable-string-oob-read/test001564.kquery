         (Ult N0:(ReadLSB w16 0 p_offset)
              256)
         (Ult 256
              N1:(ReadLSB w64 0 ps_len))
         (Ult N1 513)
         (Ult (Add w32 2 (ZExt w32 N0))
              256)
         (Eq false
             (Eq 85
