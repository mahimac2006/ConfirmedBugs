array buf[256] : w32 -> w8 = symbolic
array p_offset[2] : w32 -> w8 = symbolic
array ps_len[8] : w32 -> w8 = symbolic
array srv_len[2] : w32 -> w8 = symbolic
(query [(Ult 65533
