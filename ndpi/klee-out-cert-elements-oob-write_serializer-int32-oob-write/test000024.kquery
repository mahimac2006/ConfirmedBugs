array buf[256] : w32 -> w8 = symbolic
array p_offset[2] : w32 -> w8 = symbolic
array size_used[4] : w32 -> w8 = symbolic
array srv_len[2] : w32 -> w8 = symbolic
array value[4] : w32 -> w8 = symbolic
(query [(Ult 65533
              (ReadLSB w16 0 srv_len))
         (Ult N0:(ReadLSB w16 0 p_offset)
              256)
         (Eq false
             (Eq 0
                 N1:(ReadLSB w32 0 size_used)))
         (Ult (Add w32 11 N1) 257)
         (Ult 999999999
              (ReadLSB w32 0 value))
         (Ult (Add w32 2 (ZExt w32 N0))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N0))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N2:(Add w16 1 N0)))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N3:(ZExt w64 N2))
                      buf))
         (Eq false
             (Eq 29
                 (Read w8 (Extract w32 0 (Add w64 1 N3))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N4:(Add w16 2 N0)))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N4))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N5:(Add w16 3 N0)))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N5))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N6:(Add w16 4 N0)))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N7:(ZExt w64 N6))
                      buf))
         (Eq 29
             (Read w8 (Extract w32 0 (Add w64 1 N7))
                      buf))
         (Eq 17
             (Read w8 (Extract w32 0 (Add w64 2 N7))
                      buf))
         (Ult N8:(Add w16 7 N0) 256)
         (Ult N9:(Add w16 4
                          N10:(Add w16 (Select w16 (Eq 4
                                                       (Read w8 (Extract w32 0 (ZExt w64 N8))
                                                                buf))
                                                   4
                                                   7)
                                       N0))
              256)
         (Ult (Add w16 4
                       N11:(Add w16 N10
                                    (ZExt w16 (Select w8 (Slt N12:(Read w8 (Extract w32 0 (ZExt w64 N9))
                                                                           buf)
                                                              0)
                                                         (And w8 N12 127)
                                                         0))))
              256)
         (Ult N13:(Add w16 6 N11) 256)
         (Ult (Add w16 7
                       (Add w16 N11
                                (ZExt w16 (Select w8 (Slt N14:(Read w8 (Extract w32 0 (ZExt w64 N13))
                                                                       buf)
                                                          0)
                                                     (And w8 N14 127)
                                                     0))))
              256)]
        false)
