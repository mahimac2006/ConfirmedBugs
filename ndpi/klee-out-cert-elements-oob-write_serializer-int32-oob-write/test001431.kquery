array buf[256] : w32 -> w8 = symbolic
array p_offset[2] : w32 -> w8 = symbolic
array size_used[4] : w32 -> w8 = symbolic
array srv_len[2] : w32 -> w8 = symbolic
array value[4] : w32 -> w8 = symbolic
(query [(Ult 65533
              (ReadLSB w16 0 srv_len))
         (Ult N0:(ReadLSB w16 0 p_offset)
              256)
         (Eq false
             (Eq 0
                 N1:(ReadLSB w32 0 size_used)))
         (Ult (Add w32 11 N1) 257)
         (Ult 999999999
              (ReadLSB w32 0 value))
         (Ult (Add w32 2 (ZExt w32 N0))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N2:(ZExt w64 N0))
                      buf))
         (Eq false
             (Eq 29
                 (Read w8 (Extract w32 0 (Add w64 1 N2))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N3:(Add w16 1 N0)))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N3))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N4:(Add w16 2 N0)))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N5:(ZExt w64 N4))
                      buf))
         (Eq 29
             (Read w8 (Extract w32 0 (Add w64 1 N5))
                      buf))
         (Eq false
             (Eq 17
                 (Read w8 (Extract w32 0 (Add w64 2 N5))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 (Add w16 3 N0)))
              256)
         (Ult (Add w32 2
                       (ZExt w32 N6:(Add w16 4 N0)))
              256)
         (Eq 85
             (Read w8 (Extract w32 0 N7:(ZExt w64 N6))
                      buf))
         (Eq false
             (Eq 29
                 (Read w8 (Extract w32 0 (Add w64 1 N7))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N8:(Add w16 5 N0)))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N8))
                          buf)))
         (Ult (Add w32 2
                       (ZExt w32 N9:(Add w16 6 N0)))
              256)
         (Eq false
             (Eq 85
                 (Read w8 (Extract w32 0 (ZExt w64 N9))
                          buf)))]
        false)
