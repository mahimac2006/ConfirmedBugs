array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult 125798056984577
              N1:(Add w64 125798056984576 (ZExt w64 N0)))
         (Eq 34 (Read w8 1 buf))
         (Ult 125798056984578 N1)
         (Eq false
             (Eq 34 (Read w8 2 buf)))
         (Eq false (Ult 125798056984579 N1))
         (Eq 254 (Read w8 0 buf))]
        false)
