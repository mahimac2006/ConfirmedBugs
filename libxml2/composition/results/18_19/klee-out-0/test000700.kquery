array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Ult N1 224)
         (Eq false
             (Ult N2:(Add w64 132003739467776 (ZExt w64 N0))
                  132003739467778))
         (Ult 132003739467778 N2)
         (Ult 132003739467779 N2)
         (Ult (ZExt w32 (Read w8 3 buf))
              128)
         (Ult 132003739467780 N2)
         (Ult (ZExt w32 (Read w8 4 buf))
              128)
         (Eq false (Ult 132003739467781 N2))
         (Eq false
             (Eq 34 N3:(Read w8 1 buf)))
         (Eq false (Eq 39 N3))
         (Eq 34 (Read w8 2 buf))]
        false)
