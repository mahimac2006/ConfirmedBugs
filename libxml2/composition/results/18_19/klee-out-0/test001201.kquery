array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Ult N1 224)
         (Eq false
             (Ult N2:(Add w64 132003739467776 (ZExt w64 N0))
                  132003739467778))
         (Ult 132003739467778 N2)
         (Eq false
             (Ult N3:(ZExt w32 (Read w8 2 buf))
                  128))
         (Ult N3 224)
         (Eq false (Ult N2 132003739467780))
         (Ult 132003739467780 N2)
         (Eq false
             (Ult N4:(ZExt w32 (Read w8 4 buf))
                  128))
         (Ult N4 224)
         (Eq false (Ult N2 132003739467782))
         (Ult 132003739467782 N2)
         (Eq false
             (Ult N5:(ZExt w32 (Read w8 6 buf))
                  128))
         (Ult N5 224)
         (Eq false (Ult N2 132003739467784))
         (Eq false (Ult 132003739467784 N2))]
        false)
