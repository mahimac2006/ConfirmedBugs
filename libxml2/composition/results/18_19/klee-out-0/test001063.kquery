array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult (ZExt w32 (Read w8 0 buf))
              128)
         (Ult 132003739467777
              N1:(Add w64 132003739467776 (ZExt w64 N0)))
         (Ult (ZExt w32 (Read w8 1 buf))
              128)
         (Ult 132003739467778 N1)
         (Eq false
             (Ult N2:(ZExt w32 (Read w8 2 buf))
                  128))
         (Ult N2 224)
         (Eq false (Ult N1 132003739467780))
         (Ult 132003739467780 N1)
         (Eq false
             (Ult N3:(ZExt w32 (Read w8 4 buf))
                  128))
         (Eq false (Ult N3 224))
         (Eq false
             (Ult N1
                  N4:(Add w64 132003739467780
                              N5:(SExt w64 (Select w32 (Ult N3 240) 3 4)))))
         (Ult N4 N1)
         (Eq false
             (Ult N6:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 4 N5))
                                        buf))
                  128))
         (Ult N6 224)
         (Eq false
             (Ult N1 (Add w64 132003739467782 N5)))]
        false)
