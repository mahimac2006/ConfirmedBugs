array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Eq false (Ult N1 224))
         (Eq false
             (Ult N2:(Add w64 132003739467776 (ZExt w64 N0))
                  N3:(Add w64 132003739467776
                              N4:(SExt w64 (Select w32 (Ult N1 240) 3 4)))))
         (Ult N3 N2)
         (Eq false
             (Ult N5:(ZExt w32 (Read w8 (Extract w32 0 N4)
                                        buf))
                  128))
         (Eq false (Ult N5 224))
         (Ult N2
              (Add w64 132003739467776
                       (Add w64 N4
                                (SExt w64 (Select w32 (Ult N5 240) 3 4)))))
         (Eq 34 (Read w8 1 buf))
         (Eq false
             (Eq 34 (Read w8 2 buf)))
         (Eq 34 (Read w8 3 buf))
         (Eq false (Ult 132003739467781 N2))]
        false)
