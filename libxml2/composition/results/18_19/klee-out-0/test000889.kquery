array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult (ZExt w32 N1:(Read w8 0 buf))
              128)
         (Ult 132003739467777
              N2:(Add w64 132003739467776 (ZExt w64 N0)))
         (Eq false
             (Ult N3:(ZExt w32 (Read w8 1 buf))
                  128))
         (Eq false (Ult N3 224))
         (Eq false
             (Ult N2
                  N4:(Add w64 132003739467777
                              (SExt w64 (Select w32 (Ult N3 240) 3 4)))))
         (Eq false (Ult N4 N2))
         (Eq false (Eq 34 N1))
         (Eq false (Eq 39 N1))
         (Eq 39 (Read w8 2 buf))
         (Eq false
             (Eq 39 (Read w8 3 buf)))
         (Eq false (Ult 132003739467780 N2))]
        false)
