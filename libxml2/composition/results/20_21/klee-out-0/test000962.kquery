         (Ult N3 224)
         (Eq false (Ult N1 126954021847043))
         (Ult 126954021847043 N1)
         (Eq false
             (Eq 39 N4:(Read w8 3 buf)))
         (Eq false
             (Ult N5:(ZExt w32 N4) 128))
         (Ult N5 224)
