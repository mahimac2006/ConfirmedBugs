array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 126954021847041
              N1:(Add w64 126954021847040 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Ult (ZExt w32 N2) 128)
         (Ult 126954021847042 N1)
         (Eq false
             (Eq 34 N3:(Read w8 2 buf)))
         (Eq false
             (Ult N4:(ZExt w32 N3) 128))
         (Eq false (Ult N4 224))
         (Eq false
             (Ult N1
                  N5:(Add w64 126954021847042
                              N6:(SExt w64 (Select w32 (Ult N4 240) 3 4)))))
         (Ult N5 N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 2 N6))
                      buf))
         (Ult (Add w64 126954021847043 N6) N1)
         (Eq 39
             (Read w8 (Extract w32 0 (Add w64 3 N6))
                      buf))
         (Eq false
             (Ult (Add w64 126954021847044 N6) N1))]
        false)
