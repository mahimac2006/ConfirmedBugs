array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 126954021847041
              N1:(Add w64 126954021847040 (ZExt w64 N0)))
         (Eq 34 (Read w8 1 buf))
         (Ult 126954021847042 N1)
         (Eq 34 (Read w8 2 buf))
         (Ult 126954021847043 N1)
         (Eq false
             (Eq 34 N2:(Read w8 3 buf)))
         (Eq false
             (Ult N3:(ZExt w32 N2) 128))
         (Ult N3 224)
         (Eq false (Ult N1 126954021847045))
         (Ult 126954021847045 N1)
         (Eq false
             (Eq 34 N4:(Read w8 5 buf)))
         (Eq false
             (Ult N5:(ZExt w32 N4) 128))
         (Eq false (Ult N5 224))
         (Eq false
             (Ult N1
                  N6:(Add w64 126954021847045
                              (SExt w64 (Select w32 (Ult N5 240) 3 4)))))
         (Eq false (Ult N6 N1))]
        false)
