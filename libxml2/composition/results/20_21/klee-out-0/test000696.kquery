array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 126954021847041
              N1:(Add w64 126954021847040 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Ult (ZExt w32 N2) 128)
         (Ult 126954021847042 N1)
         (Eq false
             (Eq 34 N3:(Read w8 2 buf)))
         (Ult (ZExt w32 N3) 128)
         (Ult 126954021847043 N1)
         (Eq 34 (Read w8 3 buf))
         (Ult 126954021847044 N1)
         (Eq 39 (Read w8 4 buf))
         (Ult 126954021847045 N1)
         (Eq 39 (Read w8 5 buf))
         (Ult 126954021847046 N1)]
        false)
