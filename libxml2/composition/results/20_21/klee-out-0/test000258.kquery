array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Eq 34 N1:(Read w8 0 buf)))
         (Eq false (Eq 39 N1))
         (Ult 126954021847041
              N2:(Add w64 126954021847040 (ZExt w64 N0)))
         (Eq 34 (Read w8 1 buf))
         (Ult 126954021847042 N2)
         (Eq false
             (Eq 34 N3:(Read w8 2 buf)))
         (Ult (ZExt w32 N3) 128)
         (Ult 126954021847043 N2)
         (Eq false
             (Eq 34 N4:(Read w8 3 buf)))
         (Eq false
             (Ult N5:(ZExt w32 N4) 128))
         (Eq false (Ult N5 224))
         (Ult N2
              (Add w64 126954021847043
                       (SExt w64 (Select w32 (Ult N5 240) 3 4))))]
        false)
