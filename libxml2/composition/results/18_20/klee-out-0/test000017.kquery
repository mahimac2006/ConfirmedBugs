array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Eq false (Ult N1 224))
         (Ult N2:(Add w64 130602714005504 (ZExt w64 N0))
              (Add w64 130602714005504
                       (SExt w64 (Select w32 (Ult N1 240) 3 4))))
         (Ult 130602714005505 N2)
         (Eq 34 (Read w8 1 buf))
         (Ult 130602714005506 N2)
         (Eq false
             (Eq 34 N3:(Read w8 2 buf)))
         (Eq false
             (Ult N4:(ZExt w32 N3) 128))
         (Ult N4 224)]
        false)
