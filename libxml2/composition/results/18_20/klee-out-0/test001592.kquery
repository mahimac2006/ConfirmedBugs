array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Eq false (Ult N1 224))
         (Eq false
             (Ult N2:(Add w64 130602714005504 (ZExt w64 N0))
                  N3:(Add w64 130602714005504
                              N4:(SExt w64 (Select w32 (Ult N1 240) 3 4)))))
         (Ult N3 N2)
         (Eq false
             (Ult N5:(ZExt w32 (Read w8 (Extract w32 0 N4)
                                        buf))
                  128))
         (Eq false (Ult N5 224))
         (Eq false
             (Ult N2
                  N6:(Add w64 130602714005504
                              N7:(Add w64 N4
                                          (SExt w64 (Select w32 (Ult N5 240) 3 4))))))
         (Ult N6 N2)
         (Ult (ZExt w32 (Read w8 (Extract w32 0 N7)
                                 buf))
              128)
         (Eq false
             (Ult (Add w64 130602714005505 N7) N2))
         (Eq false
             (Eq 34 N8:(Read w8 1 buf)))
         (Eq false (Eq 39 N8))
         (Eq 39 (Read w8 2 buf))]
        false)
