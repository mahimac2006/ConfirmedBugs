array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult (ZExt w32 N1:(Read w8 0 buf))
              128)
         (Ult 130602714005505
              N2:(Add w64 130602714005504 (ZExt w64 N0)))
         (Ult (ZExt w32 N3:(Read w8 1 buf))
              128)
         (Ult 130602714005506 N2)
         (Ult 130602714005507 N2)
         (Eq false
             (Ult N4:(ZExt w32 (Read w8 3 buf))
                  128))
         (Ult N4 224)
         (Ult N2 130602714005509)
         (Eq false (Eq 34 N1))
         (Eq false (Eq 39 N1))
         (Eq false (Eq 34 N3))
         (Eq false (Eq 39 N3))
         (Eq 39 (Read w8 2 buf))]
        false)
