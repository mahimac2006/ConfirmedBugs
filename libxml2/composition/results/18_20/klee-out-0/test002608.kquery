array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Ult N1 224)
         (Eq false
             (Ult N2:(Add w64 130602714005504 (ZExt w64 N0))
                  130602714005506))
         (Ult 130602714005506 N2)
         (Ult 130602714005507 N2)
         (Ult (ZExt w32 N3:(Read w8 3 buf))
              128)
         (Ult 130602714005508 N2)
         (Eq false
             (Ult N4:(ZExt w32 (Read w8 4 buf))
                  128))
         (Ult N4 224)
         (Eq false (Ult N2 130602714005510))
         (Eq false (Ult 130602714005510 N2))
         (Eq 34 (Read w8 1 buf))
         (Eq 34 (Read w8 2 buf))
         (Eq false (Eq 34 N3))]
        false)
