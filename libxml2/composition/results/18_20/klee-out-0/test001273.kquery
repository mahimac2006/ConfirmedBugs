array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult 130602714005505
              N1:(Add w64 130602714005504 (ZExt w64 N0)))
         (Ult 130602714005506 N1)
         (Ult 130602714005507 N1)
         (Eq false
             (Ult N2:(ZExt w32 (Read w8 3 buf))
                  128))
         (Ult N2 224)
         (Ult N1 130602714005509)
         (Eq 39 (Read w8 0 buf))
         (Eq 39 (Read w8 1 buf))
         (Eq 39 (Read w8 2 buf))]
        false)
