         (Ult 131998683234307 N2)
         (Eq false
             (Ult N3:(ZExt w32 (Read w8 3 buf))
                  128))
         (Ult N3 224)
         (Eq false (Ult N2 131998683234309))
         (Ult 131998683234309 N2)
         (Eq false
             (Ult N4:(ZExt w32 (Read w8 5 buf))
                  128))
         (Ult N4 224)
         (Eq false (Ult N2 131998683234311))
         (Ult 131998683234311 N2)
         (Ult (ZExt w32 (Read w8 7 buf))
