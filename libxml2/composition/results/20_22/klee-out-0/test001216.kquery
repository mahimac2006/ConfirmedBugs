array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult 129969200037889
              N1:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq 39 (Read w8 1 buf))
         (Ult 129969200037890 N1)
         (Eq false
             (Eq 39 N2:(Read w8 2 buf)))
         (Eq false
             (Ult N3:(ZExt w32 N2) 128))
         (Eq false (Ult N3 224))
         (Eq false
             (Ult N1
                  N4:(Add w64 129969200037890
                              (SExt w64 (Select w32 (Ult N3 240) 3 4)))))
         (Eq false (Ult N4 N1))
         (Eq 255 (Read w8 0 buf))
         (Eq false
             (Eq 1 (URem w32 N0 2)))]
        false)
