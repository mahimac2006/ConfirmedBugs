array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Eq 34 N1:(Read w8 0 buf)))
         (Eq false (Eq 39 N1))
         (Ult 129969200037889
              N2:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N3:(Read w8 1 buf)))
         (Eq false (Eq 39 N3))
         (Ult 129969200037890 N2)
         (Eq 34 (Read w8 2 buf))
         (Ult 129969200037891 N2)
         (Eq false
             (Eq 34 N4:(Read w8 3 buf)))
         (Ult (ZExt w32 N4) 128)
         (Ult 129969200037892 N2)
         (Eq false
             (Eq 34 N5:(Read w8 4 buf)))
         (Eq false
             (Ult N6:(ZExt w32 N5) 128))
         (Eq false (Ult N6 224))
         (Ult N2
              (Add w64 129969200037892
                       (SExt w64 (Select w32 (Ult N6 240) 3 4))))]
        false)
