array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Eq 34 N1:(Read w8 0 buf)))
         (Eq false (Eq 39 N1))
         (Ult 129969200037889
              N2:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq 34 (Read w8 1 buf))
         (Ult 129969200037890 N2)
         (Eq false
             (Eq 34 N3:(Read w8 2 buf)))
         (Eq false
             (Ult N4:(ZExt w32 N3) 128))
         (Eq false (Ult N4 224))
         (Eq false
             (Ult N2
                  N5:(Add w64 129969200037890
                              N6:(SExt w64 (Select w32 (Ult N4 240) 3 4)))))
         (Ult N5 N2)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 2 N6))
                      buf))
         (Ult (Add w64 129969200037891 N6) N2)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 3 N6))
                      buf))
         (Ult (Add w64 129969200037892 N6) N2)
         (Eq false
             (Eq 34
                 (Read w8 (Extract w32 0 (Add w64 4 N6))
                          buf)))]
        false)
