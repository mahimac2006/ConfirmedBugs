array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 129969200037889
              N1:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Eq false
             (Ult N3:(ZExt w32 N2) 128))
         (Ult N3 224)
         (Eq false (Ult N1 129969200037891))
         (Ult 129969200037891 N1)
         (Eq false
             (Eq 34 N4:(Read w8 3 buf)))
         (Ult (ZExt w32 N4) 128)
         (Ult 129969200037892 N1)
         (Eq 34 (Read w8 4 buf))
         (Ult 129969200037893 N1)
         (Eq 34 (Read w8 5 buf))
         (Ult 129969200037894 N1)
         (Eq false
             (Eq 34 (Read w8 6 buf)))]
        false)
