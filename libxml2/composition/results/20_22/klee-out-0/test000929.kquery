array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult 129969200037889
              N1:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Eq false (Eq 39 N2))
         (Ult 129969200037890 N1)
         (Eq 39 (Read w8 2 buf))
         (Ult 129969200037891 N1)
         (Eq 39 (Read w8 3 buf))
         (Eq false (Ult 129969200037892 N1))
         (Eq 255 (Read w8 0 buf))]
        false)
