array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Eq 34 N1:(Read w8 0 buf)))
         (Eq false (Eq 39 N1))
         (Ult 129969200037889
              N2:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq 34 (Read w8 1 buf))
         (Ult 129969200037890 N2)
         (Eq 34 (Read w8 2 buf))
         (Ult 129969200037891 N2)
         (Eq 39 (Read w8 3 buf))
         (Ult 129969200037892 N2)
         (Eq false
             (Eq 39 N3:(Read w8 4 buf)))
         (Ult (ZExt w32 N3) 128)
         (Ult 129969200037893 N2)
         (Eq 39 (Read w8 5 buf))]
        false)
