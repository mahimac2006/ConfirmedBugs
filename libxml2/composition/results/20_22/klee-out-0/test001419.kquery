array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 129969200037889
              N1:(Add w64 129969200037888 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Eq false
             (Ult N3:(ZExt w32 N2) 128))
         (Eq false (Ult N3 224))
         (Eq false
             (Ult N1
                  N4:(Add w64 129969200037889
                              N5:(SExt w64 (Select w32 (Ult N3 240) 3 4)))))
         (Ult N4 N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 1 N5))
                      buf))
         (Ult (Add w64 129969200037890 N5) N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 2 N5))
                      buf))
         (Ult (Add w64 129969200037891 N5) N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 3 N5))
                      buf))
         (Ult (Add w64 129969200037892 N5) N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 4 N5))
                      buf))
         (Ult (Add w64 129969200037893 N5) N1)
         (Eq 34
             (Read w8 (Extract w32 0 (Add w64 5 N5))
                      buf))]
        false)
