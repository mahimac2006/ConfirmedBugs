array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq 34 (Read w8 0 buf))
         (Ult 130954047782913
              N1:(Add w64 130954047782912 (ZExt w64 N0)))
         (Eq false
             (Eq 34 N2:(Read w8 1 buf)))
         (Ult 130954047782914 N1)
         (Eq false
