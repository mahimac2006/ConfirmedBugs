         (Ult 130954047782915 N1)
         (Eq 34 (Read w8 3 buf))
         (Ult 130954047782916 N1)
         (Eq 34 (Read w8 4 buf))
         (Ult 130954047782917 N1)
         (Eq false
             (Eq 34 (Read w8 5 buf)))
         (Ult 130954047782918 N1)
         (Eq 34 (Read w8 6 buf))
         (Ult 130954047782919 N1)
         (Eq false
             (Eq 34 N3:(Read w8 7 buf)))
         (Eq false (Eq 39 N3))
         (Eq false (Ult 130954047782920 N1))
         (Eq false
             (Ult N4:(ZExt w32 N2) 128))
         (Eq false (Ult N4 224))
         (Eq false
