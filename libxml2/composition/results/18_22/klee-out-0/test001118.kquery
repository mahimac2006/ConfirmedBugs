array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 N2:(Read w8 0 buf))
                  128))
         (Eq false (Ult N1 224))
         (Eq false
             (Ult N3:(Add w64 138146102640640 (ZExt w64 N0))
                  N4:(Add w64 138146102640640
                              N5:(SExt w64 (Select w32 (Ult N1 240) 3 4)))))
         (Ult N4 N3)
         (Eq false
             (Ult N6:(ZExt w32 (Read w8 (Extract w32 0 N5)
                                        buf))
                  128))
         (Ult N6 224)
         (Eq false
             (Ult N3 N7:(Add w64 138146102640642 N5)))
         (Ult N7 N3)
         (Ult (ZExt w32 (Read w8 (Extract w32 0 (Add w64 2 N5))
                                 buf))
              128)
         (Ult (Add w64 138146102640643 N5) N3)
         (Eq false
             (Ult N8:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 3 N5))
                                        buf))
                  128))
         (Eq false (Ult N8 224))
         (Eq false
             (Ult N3
                  N9:(Add w64 138146102640643
                              N10:(Add w64 N5
                                           (SExt w64 (Select w32 (Ult N8 240) 3 4))))))
         (Ult N9 N3)
         (Ult (ZExt w32 (Read w8 (Extract w32 0 (Add w64 3 N10))
                                 buf))
              128)
         (Eq false
             (Ult (Add w64 138146102640644 N10) N3))
         (Eq false (Eq 254 N2))]
        false)
