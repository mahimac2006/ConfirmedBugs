array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Ult (Add w64 138146102640640 (ZExt w64 N0))
              138146102640644)
         (Eq 254 (Read w8 0 buf))
         (Eq 1 (URem w32 N0 2))]
        false)
