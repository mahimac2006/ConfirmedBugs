array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(ZExt w32 (Read w8 0 buf))
                  128))
         (Ult N1 224)
         (Eq false
             (Ult N2:(Add w64 138146102640640 (ZExt w64 N0))
                  138146102640642))
         (Ult 138146102640642 N2)
         (Ult (ZExt w32 (Read w8 2 buf))
              128)
         (Ult 138146102640643 N2)
         (Eq false
             (Ult N3:(ZExt w32 (Read w8 3 buf))
                  128))
         (Ult N3 224)
         (Eq false (Ult N2 138146102640645))
         (Ult 138146102640645 N2)
         (Ult (ZExt w32 (Read w8 5 buf))
              128)
         (Ult 138146102640646 N2)
         (Eq false
             (Ult N4:(ZExt w32 (Read w8 6 buf))
                  128))
         (Eq false (Ult N4 224))
         (Eq false
             (Ult N2
                  N5:(Add w64 138146102640646
                              N6:(SExt w64 (Select w32 (Ult N4 240) 3 4)))))
         (Ult N5 N2)
         (Eq false
             (Ult N7:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 6 N6))
                                        buf))
                  128))
         (Eq false (Ult N7 224))
         (Eq false
             (Ult N2
                  (Add w64 138146102640646
                           (Add w64 N6
                                    (SExt w64 (Select w32 (Ult N7 240) 3 4))))))]
        false)
