array buf[32] : w32 -> w8 = symbolic
array len[4] : w32 -> w8 = symbolic
(query [(Ule 1
              N0:(ReadLSB w32 0 len))
         (Ule N0 32)
         (Eq false
             (Ult N1:(Add w64 138146102640640 (ZExt w64 N0))
                  138146102640644))
         (Ult 138146102640644 N1)
         (Ult (ZExt w32 (Read w8 4 buf))
              128)
         (Ult 138146102640645 N1)
         (Ult (ZExt w32 (Read w8 5 buf))
              128)
         (Ult 138146102640646 N1)
         (Eq false
             (Ult N2:(ZExt w32 (Read w8 6 buf))
                  128))
         (Eq false (Ult N2 224))
         (Eq false
             (Ult N1
                  N3:(Add w64 138146102640646
                              N4:(SExt w64 (Select w32 (Ult N2 240) 3 4)))))
         (Ult N3 N1)
         (Eq false
             (Ult N5:(ZExt w32 (Read w8 (Extract w32 0 (Add w64 6 N4))
                                        buf))
                  128))
         (Ult N5 224)
         (Ult N1 (Add w64 138146102640648 N4))
         (Eq 255 (Read w8 0 buf))
         (Eq 1 (URem w32 N0 2))]
        false)
